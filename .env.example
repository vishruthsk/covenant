# Environment variables for COVENANT agents

# RPC endpoint (use local hardhat node for testing)
RPC_URL=http://127.0.0.1:8545

# Deployed contract address (update after deployment)
CONTRACT_ADDRESS=

# Executor agent private key (DO NOT commit real keys)
EXECUTOR_PRIVATE_KEY=

# Verifier agent private key (DO NOT commit real keys)
VERIFIER_PRIVATE_KEY=

# Task creator private key (for testing)
CREATOR_PRIVATE_KEY=

# Monad RPC URL (when deploying to Monad)
MONAD_RPC_URL=
