# ============================================================================
# COVENANT Agent Configuration
# ============================================================================
# This file contains all environment variables needed to run COVENANT agents.
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control!

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# RPC endpoint for blockchain connection
# For local development, use Hardhat's default RPC endpoint
# For production, use a reliable RPC provider (Alchemy, Infura, etc.)
RPC_URL=http://127.0.0.1:8545

# Deployed CovenantEscrow contract address
# Update this after running: npm run deploy:localhost
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Executor agent private key (32-byte hex string with 0x prefix)
# For local testing, use one of Hardhat's default accounts
# Example: Account #2 from Hardhat node
EXECUTOR_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a

# Verifier agent private key (32-byte hex string with 0x prefix)
# Must be different from executor key
# Example: Account #1 from Hardhat node
VERIFIER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# Task creator private key (for testing task creation)
# Example: Account #3 from Hardhat node
CREATOR_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# ============================================================================
# OPTIONAL CONFIGURATION (Production Features)
# ============================================================================

# Demo Mode - Set to 'true' to run agents without sending real transactions
# Useful for safe demonstrations and testing
# Default: false (live transactions)
DEMO_MODE=false

# Minimum escrow amount (in ETH) for executor to accept tasks
# Tasks with lower escrow will be rejected
# Default: 0.01 ETH
MIN_ESCROW_ETH=0.01

# Maximum retry attempts for failed RPC calls
# Uses exponential backoff between retries
# Default: 3
RETRY_ATTEMPTS=3

# Initial retry delay in milliseconds
# Doubles with each retry attempt (exponential backoff)
# Default: 1000ms (1 second)
RETRY_DELAY_MS=1000

# Delay after accepting task before submitting result (milliseconds)
# Allows time for transaction confirmation
# Default: 2000ms (2 seconds)
TASK_PROCESSING_DELAY_MS=2000

# Delay after result submission before verification (milliseconds)
# Allows time for transaction confirmation
# Default: 2000ms (2 seconds)
VERIFICATION_DELAY_MS=2000

# Logging level: DEBUG, INFO, WARN, ERROR
# DEBUG: All logs including detailed state transitions
# INFO: Normal operational logs (recommended)
# WARN: Only warnings and errors
# ERROR: Only errors
# Default: INFO
LOG_LEVEL=INFO

# ============================================================================
# PRODUCTION DEPLOYMENT (Monad or other networks)
# ============================================================================

# Monad RPC URL (when deploying to Monad testnet/mainnet)
# Leave empty for local development
MONAD_RPC_URL=

# Production private keys (NEVER use test keys in production!)
# Use hardware wallets or secure key management systems
# PRODUCTION_EXECUTOR_PRIVATE_KEY=
# PRODUCTION_VERIFIER_PRIVATE_KEY=

# ============================================================================
# OPERATIONAL NOTES
# ============================================================================
#
# 1. STARTUP SEQUENCE:
#    - Start Hardhat node: npm run node
#    - Deploy contract: npm run deploy:localhost
#    - Update CONTRACT_ADDRESS in .env
#    - Start executor: npm run executor
#    - Start verifier: npm run verifier
#    - Create test task: npm run create-task
#
# 2. AGENT BEHAVIOR:
#    - Agents validate configuration on startup (fail-fast)
#    - Agents retry transient RPC failures automatically
#    - Agents enter ERROR state after 5 consecutive RPC failures
#    - Agents handle SIGINT/SIGTERM for graceful shutdown
#    - Agents prevent double-processing of tasks
#
# 3. DEMO MODE:
#    - Set DEMO_MODE=true for safe demonstrations
#    - Agents will log actions but skip actual transactions
#    - Useful for repeated demo runs without spending gas
#
# 4. MONITORING:
#    - Watch for state transitions: IDLE → PROCESSING → IDLE
#    - Check for ERROR state (indicates RPC or config issues)
#    - Monitor consecutive failure counts
#    - All logs include timestamps and task IDs
#
# 5. TROUBLESHOOTING:
#    - "Missing required environment variables" → Check .env file
#    - "Cannot connect to RPC" → Verify Hardhat node is running
#    - "No contract deployed" → Run npm run deploy:localhost
#    - "Insufficient balance" → Fund agent wallets
#    - "Circuit breaker triggered" → Check RPC connectivity
#
# ============================================================================
